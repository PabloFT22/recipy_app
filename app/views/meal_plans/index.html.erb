<div class="mp-container">
  <div class="flex justify-between items-center mb-4">
    <h1>My Meal Plans</h1>
    <%= link_to "➕ Create Meal Plan", new_meal_plan_path, class: "btn btn-success" %>
  </div>

  <% if @meal_plans.any? %>
    <div class="grid grid-3">
      <% @meal_plans.each do |plan| %>
        <%
          today = Date.current
          status = if plan.start_date <= today && plan.end_date >= today
                     :active
                   elsif plan.start_date > today
                     :upcoming
                   else
                     :past
                   end
        %>
        <div class="mp-card <%= 'mp-card--active' if status == :active %>">
          <div class="mp-card-header">
            <h3 class="mp-card-title"><%= link_to plan.name, plan %></h3>
            <span class="mp-status-badge mp-status-<%= status %>"><%= status.to_s.capitalize %></span>
          </div>

          <div class="mp-card-body">
            <div class="mp-card-meta">
              <span class="mp-card-date">
                📅 <%= plan.start_date.strftime('%b %d') %> — <%= plan.end_date.strftime('%b %d, %Y') %>
              </span>
              <span class="mp-card-count">
                🍽️ <%= plan.total_recipes %> <%= 'recipe'.pluralize(plan.total_recipes) %>
              </span>
            </div>

            <div class="mp-card-days">
              <%= pluralize((plan.end_date - plan.start_date).to_i + 1, 'day') %>
            </div>
          </div>

          <div class="mp-card-actions">
            <%= link_to "View", plan, class: "btn" %>
            <%= link_to "Edit", edit_meal_plan_path(plan), class: "btn btn-secondary" %>
            <%= link_to "Delete", plan, data: { turbo_method: :delete, turbo_confirm: "Delete this meal plan?" }, class: "btn btn-danger" %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-4 text-center">
      <%= paginate @meal_plans %>
    </div>
  <% else %>
    <div class="card text-center">
      <div class="empty-state">
        <span class="empty-icon">📅</span>
        <h3>No meal plans yet</h3>
        <p>Start planning your meals for the week!</p>
        <%= link_to "Create Your First Meal Plan", new_meal_plan_path, class: "btn btn-success mt-2" %>
      </div>
    </div>
  <% end %>
</div>
