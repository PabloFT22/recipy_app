<!DOCTYPE html>
<html>
  <body>
    <h1>Hello <%= @user.display_name %>!</h1>
    <p>Here's your meal plan for today from <strong><%= @meal_plan.name %></strong>:</p>

    <% @today_recipes.each do |mpr| %>
      <div style="border: 1px solid #ddd; padding: 1rem; margin-bottom: 1rem; border-radius: 4px;">
        <h3><%= mpr.recipe.title %></h3>
        <p><strong>Meal type:</strong> <%= mpr.meal_type.capitalize %></p>
        <p><strong>Servings:</strong> <%= mpr.servings %></p>
        <% if mpr.recipe.prep_time || mpr.recipe.cook_time %>
          <p><strong>Time:</strong> <%= mpr.recipe.total_time %> minutes</p>
        <% end %>
      </div>
    <% end %>

    <p>Happy cooking!</p>
    <p>— The Recipy Team</p>
  </body>
</html>
