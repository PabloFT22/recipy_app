<!DOCTYPE html>
<html>
  <body>
    <h1>Your Weekly Recipe Digest</h1>
    <p>Hello <%= @user.display_name %>! Here are new recipes from people you follow:</p>

    <% @recipes.each do |recipe| %>
      <div style="border: 1px solid #ddd; padding: 1rem; margin-bottom: 1rem; border-radius: 4px;">
        <h3><%= recipe.title %></h3>
        <p>By <%= recipe.user.display_name %></p>
        <% if recipe.description.present? %>
          <p><%= truncate(recipe.description, length: 150) %></p>
        <% end %>
      </div>
    <% end %>

    <p>— The Recipy Team</p>
  </body>
</html>
