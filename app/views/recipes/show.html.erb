<div class="recipe-show-container">
  <!-- Recipe Header -->
  <div class="recipe-header">
    <div class="recipe-header-content">
      <div class="recipe-title-section">
        <h1 class="recipe-title"><%= @recipe.title %></h1>
        
        <% if @recipe.description.present? %>
          <p class="recipe-description"><%= @recipe.description %></p>
        <% end %>

        <div class="recipe-meta">
          <% if @recipe.difficulty.present? %>
            <span class="meta-badge difficulty-<%= @recipe.difficulty %>">
              <%= @recipe.difficulty.titleize %>
            </span>
          <% end %>

          <% if @recipe_tags.any? %>
            <% @recipe_tags.each do |tag| %>
              <%= link_to tag.name, recipes_path(tag: tag.id), class: "tag-badge" %>
            <% end %>
          <% end %>

          <% if @recipe.dietary_tags.present? %>
            <% @recipe.dietary_tags.split(',').each do |tag| %>
              <span class="badge"><%= tag.strip %></span>
            <% end %>
          <% end %>

          <% if @recipe.cuisine_type.present? %>
            <span class="meta-item">🌍 <%= @recipe.cuisine_type %></span>
          <% end %>

          <% if @recipe.servings.present? %>
            <span class="meta-item">
              👥 <%= @recipe.servings %> servings
            </span>
          <% end %>

          <% if @recipe.prep_time.present? %>
            <span class="meta-item">
              ⏱️ Prep: <%= @recipe.prep_time %> min
            </span>
          <% end %>

          <% if @recipe.cook_time.present? %>
            <span class="meta-item">
              🔥 Cook: <%= @recipe.cook_time %> min
            </span>
          <% end %>

          <% if @recipe.total_time %>
            <span class="meta-item total-time">
              ⏰ Total: <%= @recipe.total_time %> min
            </span>
          <% end %>

          <% if @recipe.reviews_count.to_i > 0 %>
            <span class="meta-item">
              ⭐ <%= number_with_precision(@recipe.average_rating, precision: 1) %>
              (<%= @recipe.reviews_count %> <%= 'review'.pluralize(@recipe.reviews_count) %>)
            </span>
          <% end %>

          <span class="meta-item">❤️ <%= @recipe.likes.count %></span>
        </div>

        <div class="recipe-author">
          <span>By <%= @recipe.user.display_name %></span>
          <span class="separator">•</span>
          <span><%= time_ago_in_words(@recipe.created_at) %> ago</span>
          <% unless @recipe.is_public %>
            <span class="separator">•</span>
            <span class="private-badge">🔒 Private</span>
          <% end %>
        </div>
      </div>

      <!-- Action Buttons -->
      <% if user_signed_in? %>
        <div class="recipe-actions">
          <%= link_to "👨‍🍳 Cook Mode", cook_recipe_path(@recipe), class: "btn btn-success" %>

          <% if @recipe.user == current_user %>
            <%= link_to "✏️ Edit", edit_recipe_path(@recipe), class: "btn btn-secondary" %>
            <%= link_to "🗑️ Delete", recipe_path(@recipe), 
                data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this recipe?" },
                class: "btn btn-danger" %>
          <% end %>

          <%# Like button %>
          <%= turbo_frame_tag "like_button_#{@recipe.id}" do %>
            <% if @recipe.liked_by?(current_user) %>
              <%= link_to "❤️ Liked (#{@recipe.likes.count})", unlike_recipe_path(@recipe),
                  data: { turbo_method: :delete }, class: "btn btn-secondary" %>
            <% else %>
              <%= link_to "🤍 Like (#{@recipe.likes.count})", like_recipe_path(@recipe),
                  data: { turbo_method: :post }, class: "btn" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="recipe-content">
    <!-- Recipe Image -->
    <% if @recipe.image.attached? %>
      <div class="recipe-image-container">
        <%= image_tag @recipe.image, alt: @recipe.title, class: "recipe-image" %>
      </div>
    <% end %>

    <div class="recipe-details">
      <!-- Ingredients Section -->
      <div class="recipe-section">
        <div class="section-header">
          <h2 class="section-title">
            <span class="section-icon">🥘</span>
            Ingredients
          </h2>
          <% if user_signed_in? %>
            <button class="btn btn-small btn-ghost" onclick="alert('Add to grocery list feature coming soon!')">
              🛒 Add to List
            </button>
          <% end %>
        </div>

        <% if @recipe.recipe_ingredients.any? %>
          <div class="ingredients-list">
            <% @recipe.recipe_ingredients.includes(:ingredient).each do |recipe_ingredient| %>
              <div class="ingredient-item">
                <label class="ingredient-checkbox">
                  <input type="checkbox">
                  <span class="ingredient-text">
                    <span class="ingredient-quantity">
                      <%= display_quantity(recipe_ingredient.quantity) %>
                      <%= recipe_ingredient.unit %>
                    </span>
                    <span class="ingredient-name"><%= recipe_ingredient.ingredient.name %></span>
                    <% if recipe_ingredient.notes.present? %>
                      <span class="ingredient-notes">, <%= recipe_ingredient.notes %></span>
                    <% end %>
                  </span>
                </label>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="empty-state">No ingredients added yet.</p>
        <% end %>
      </div>

      <!-- Instructions Section -->
      <div class="recipe-section">
        <div class="section-header">
          <h2 class="section-title">
            <span class="section-icon">👨‍🍳</span>
            Instructions
          </h2>
        </div>

        <% if @recipe.instructions.present? %>
          <div class="instructions-list">
            <%
              normalized = @recipe.instructions.gsub(/\r\n/, "\n")
              steps = normalized.split(/\n\n+/).reject(&:blank?)
            %>
            <% steps.each_with_index do |step, index| %>
              <% cleaned_step = step.gsub(/^\d+[\.\)]\s*|^Step\s+\d+:?\s*/i, '').strip %>
              <div class="instruction-step">
                <div class="step-number"><%= index + 1 %></div>
                <div class="step-text"><%= simple_format(cleaned_step) %></div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="empty-state">No instructions added yet.</p>
        <% end %>
      </div>

      <!-- Nutrition Info -->
      <% if @recipe.nutrition_info && @recipe.servings.to_i > 0 %>
        <div class="recipe-section">
          <div class="section-header">
            <h2 class="section-title">
              <span class="section-icon">📊</span>
              Nutrition Information
            </h2>
          </div>
          <details>
            <summary><strong>Per serving</strong></summary>
            <div class="grid grid-3 mt-3">
              <% ni = @recipe.nutrition_info.per_serving(1) %>
              <div class="text-center"><strong><%= ni.calories.to_f.round %></strong><br><small>Calories</small></div>
              <div class="text-center"><strong><%= ni.protein_g.to_f.round(1) %>g</strong><br><small>Protein</small></div>
              <div class="text-center"><strong><%= ni.carbs_g.to_f.round(1) %>g</strong><br><small>Carbs</small></div>
              <div class="text-center"><strong><%= ni.fat_g.to_f.round(1) %>g</strong><br><small>Fat</small></div>
              <div class="text-center"><strong><%= ni.fiber_g.to_f.round(1) %>g</strong><br><small>Fiber</small></div>
              <div class="text-center"><strong><%= ni.sodium_mg.to_f.round %>mg</strong><br><small>Sodium</small></div>
            </div>
          </details>
        </div>
      <% end %>

      <!-- Source Section -->
      <% if @recipe.source_url.present? %>
        <div class="recipe-section">
          <div class="section-header">
            <h2 class="section-title">
              <span class="section-icon">🔗</span>
              Source
            </h2>
          </div>
          <div class="source-link">
            <%= link_to @recipe.source_url, @recipe.source_url, target: "_blank", rel: "noopener" %>
          </div>
        </div>
      <% end %>

      <!-- Reviews Section -->
      <div class="recipe-section" id="reviews">
        <div class="section-header">
          <h2 class="section-title">
            <span class="section-icon">⭐</span>
            Reviews
          </h2>
        </div>

        <% if @reviews.any? %>
          <% @reviews.each do |review| %>
            <%= render "reviews/review", review: review %>
          <% end %>
        <% else %>
          <p class="text-muted">No reviews yet. Be the first to review this recipe!</p>
        <% end %>

        <% if user_signed_in? %>
          <% if @user_review %>
            <p class="mt-3">You've already reviewed this recipe. <%= link_to "Edit your review", edit_recipe_review_path(@recipe, @user_review) %></p>
          <% else %>
            <div class="mt-4">
              <h3>Write a Review</h3>
              <%= render "reviews/form", review: Review.new %>
            </div>
          <% end %>
        <% else %>
          <p class="mt-3"><%= link_to "Sign in", new_user_session_path %> to leave a review.</p>
        <% end %>
      </div>

      <!-- Additional Actions -->
      <% if user_signed_in? %>
        <div class="recipe-section">
          <div class="quick-actions">
            <%= link_to "📋 Duplicate Recipe", duplicate_recipe_path(@recipe), 
                data: { turbo_method: :post }, 
                class: "btn btn-secondary" %>
            
            <button class="btn btn-secondary" onclick="window.print()">
              🖨️ Print Recipe
            </button>
            
            <button class="btn btn-secondary" onclick="navigator.share ? navigator.share({title: '<%= j(@recipe.title) %>', url: window.location.href}) : alert('Share via: ' + window.location.href)">
              📤 Share
            </button>

            <div class="collection-picker-wrapper" data-controller="collection-picker">
              <button class="btn btn-secondary" data-action="click->collection-picker#toggle" type="button">
                📂 Add to Collection
              </button>
              <div class="collection-picker-dropdown" data-collection-picker-target="dropdown" style="display: none;">
                <% if current_user.recipe_collections.any? %>
                  <% current_user.recipe_collections.each do |coll| %>
                    <div class="collection-picker-item">
                      <%= form_with url: add_to_collection_recipe_path(@recipe), method: :post, local: true do |f| %>
                        <%= f.hidden_field :collection_id, value: coll.id %>
                        <%= f.submit coll.name, class: "collection-picker-option" %>
                      <% end %>
                    </div>
                  <% end %>
                <% else %>
                  <div class="collection-picker-empty">
                    <p>No collections yet.</p>
                    <%= link_to "Create one", new_recipe_collection_path %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Back Link -->
  <div class="back-link">
    <%= link_to "← Back to Recipes", recipes_path, class: "link-secondary" %>
  </div>
</div>
