<!DOCTYPE html>
<html>
  <head>
    <title>Recipy - Your Recipe Manager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Recipy">
    <meta name="theme-color" content="#2c3e50">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="manifest" href="/manifest.json">
    <link rel="apple-touch-icon" href="/icons/icon-192.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
  </head>

  <body>
    <%# PWA Install Banner %>
    <div data-controller="pwa-install" style="display: none;">
      <div data-pwa-install-target="banner"
           style="background: #2c3e50; color: white; padding: 1rem; text-align: center; display: none;">
        <span>Install Recipy for a better experience</span>
        <button data-action="click->pwa-install#install" style="margin-left: 1rem; padding: 0.25rem 0.75rem; background: white; color: #2c3e50; border: none; border-radius: 4px; cursor: pointer;">Install</button>
        <button data-action="click->pwa-install#dismiss" style="margin-left: 0.5rem; background: transparent; color: white; border: 1px solid white; border-radius: 4px; padding: 0.25rem 0.5rem; cursor: pointer;">✕</button>
      </div>
    </div>

    <nav class="navbar">
      <div class="container">
        <%= link_to "Recipy", root_path, class: "navbar-brand" %>

        <% if user_signed_in? %>
          <div class="navbar-menu">
            <%= link_to "Recipes", recipes_path, class: "nav-link" %>
            <%= link_to "Meal Plans", meal_plans_path, class: "nav-link" %>
            <%= link_to "Grocery Lists", grocery_lists_path, class: "nav-link" %>
            <%= link_to "Collections", recipe_collections_path, class: "nav-link" %>
            <%= link_to "Pantry", pantry_items_path, class: "nav-link" %>
            <%= link_to current_user.display_name, user_path(current_user), class: "nav-link" %>
            <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
          </div>
        <% else %>
          <div class="navbar-menu">
            <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "nav-link" %>
          </div>
        <% end %>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-notice">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-alert">
        <%= alert %>
      </div>
    <% end %>

    <main class="container">
      <%= yield %>
    </main>

    <footer>
      <div class="container">
        <p>&copy; 2026 Recipy. Your personal recipe manager.</p>
      </div>
    </footer>
  </body>
</html>
