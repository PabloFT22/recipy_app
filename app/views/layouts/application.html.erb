<!DOCTYPE html>
<html>
  <head>
    <title>Recipy - Your Recipe Manager</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <div class="container">
        <%= link_to "Recipy", root_path, class: "navbar-brand" %>
        
        <% if user_signed_in? %>
          <div class="navbar-menu">
            <%= link_to "Recipes", recipes_path, class: "nav-link" %>
            <%= link_to "Meal Plans", meal_plans_path, class: "nav-link" %>
            <%= link_to "Grocery Lists", grocery_lists_path, class: "nav-link" %>
            <%= link_to "Collections", recipe_collections_path, class: "nav-link" %>
            <%= link_to "Sign Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-link" %>
          </div>
        <% else %>
          <div class="navbar-menu">
            <%= link_to "Sign In", new_user_session_path, class: "nav-link" %>
            <%= link_to "Sign Up", new_user_registration_path, class: "nav-link" %>
          </div>
        <% end %>
      </div>
    </nav>

    <% if notice %>
      <div class="alert alert-notice">
        <%= notice %>
      </div>
    <% end %>

    <% if alert %>
      <div class="alert alert-alert">
        <%= alert %>
      </div>
    <% end %>

    <main class="container">
      <%= yield %>
    </main>
    
    <footer>
      <div class="container">
        <p>&copy; 2026 Recipy. Your personal recipe manager.</p>
      </div>
    </footer>
  </body>
</html>
