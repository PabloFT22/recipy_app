<div class="mb-3">
  <%= link_to "← Back to Profile", @user %>
</div>

<h1>Edit Profile</h1>

<div class="card">
  <%= form_with model: @user, url: user_path(@user), method: :patch, local: true, multipart: true do |f| %>
    <% if @user.errors.any? %>
      <div class="alert alert-alert">
        <% @user.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="form-group mb-3">
      <%= f.label :avatar, "Profile Photo" %>
      <%= f.file_field :avatar, class: "form-control", accept: "image/*" %>
      <% if @user.avatar.attached? %>
        <div class="mt-2">
          <%= image_tag @user.avatar.variant(resize_to_fill: [80, 80]), style: "width: 80px; height: 80px; border-radius: 50%; object-fit: cover;" %>
        </div>
      <% end %>
    </div>

    <div class="form-group mb-3">
      <%= f.label :name, "Display Name" %>
      <%= f.text_field :name, class: "form-control", placeholder: "Your full name" %>
    </div>

    <div class="form-group mb-3">
      <%= f.label :username %>
      <%= f.text_field :username, class: "form-control", placeholder: "username" %>
    </div>

    <div class="form-group mb-3">
      <%= f.label :bio %>
      <%= f.text_area :bio, class: "form-control", rows: 4,
          placeholder: "Tell others about yourself..." %>
    </div>

    <div class="flex gap-2">
      <%= f.submit "Update Profile", class: "btn" %>
      <%= link_to "Cancel", @user, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
