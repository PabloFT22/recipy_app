<div class="recipe-form-container">
  <div class="recipe-form-header">
    <h1><%= recipe.new_record? ? 'Create New Recipe' : 'Edit Recipe' %></h1>
    <p class="subtitle"><%= recipe.new_record? ? 'Build your recipe step by step' : 'Update your recipe details' %></p>
  </div>

  <%= form_with(model: recipe, class: "recipe-form", data: { controller: "recipe-form" }) do |form| %>
    <% if recipe.errors.any? %>
      <div class="alert alert-error">
        <h3><%= pluralize(recipe.errors.count, "error") %> prevented this recipe from being saved:</h3>
        <ul>
          <% recipe.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Basic Info Card -->
    <div class="form-card" data-recipe-form-target="card" data-card="basic">
      <div class="card-header" data-action="click->recipe-form#toggleCard">
        <div class="card-title">
          <span class="card-icon">📝</span>
          <h3>Basic Information</h3>
          <span class="card-status" data-recipe-form-target="basicStatus">Required</span>
        </div>
        <button type="button" class="expand-btn" data-recipe-form-target="basicToggle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
      
      <div class="card-body" data-recipe-form-target="basicBody">
        <div class="form-group">
          <%= form.label :title, "Recipe Name *" %>
          <%= form.text_field :title, 
              placeholder: "e.g., Grandma's Chocolate Chip Cookies",
              class: "form-input",
              data: { action: "input->recipe-form#updatePreview" },
              autofocus: true %>
        </div>

        <div class="form-group">
          <%= form.label :description, "Description" %>
          <%= form.text_area :description, 
              rows: 3,
              placeholder: "Brief description of your recipe...",
              class: "form-input",
              data: { action: "input->recipe-form#updatePreview" } %>
        </div>

        <div class="form-row">
          <div class="form-group">
            <%= form.label :difficulty, "Difficulty" %>
            <%= form.select :difficulty, 
                [['Easy', 'easy'], ['Medium', 'medium'], ['Hard', 'hard']], 
                { prompt: 'Select difficulty' },
                class: "form-select" %>
          </div>

          <div class="form-group">
            <%= form.label :servings, "Servings" %>
            <%= form.number_field :servings, 
                placeholder: "4",
                min: 1,
                class: "form-input" %>
          </div>
        </div>

        <div class="form-group">
          <%= form.label :is_public, class: "checkbox-label" do %>
            <%= form.check_box :is_public %>
            <span>Make this recipe public</span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Timing Card -->
    <div class="form-card" data-recipe-form-target="card" data-card="timing">
      <div class="card-header" data-action="click->recipe-form#toggleCard">
        <div class="card-title">
          <span class="card-icon">⏱️</span>
          <h3>Cooking Time</h3>
          <span class="card-status">Optional</span>
        </div>
        <button type="button" class="expand-btn" data-recipe-form-target="timingToggle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
      
      <div class="card-body collapsed" data-recipe-form-target="timingBody">
        <div class="form-row">
          <div class="form-group">
            <%= form.label :prep_time, "Prep Time (minutes)" %>
            <%= form.number_field :prep_time, 
                placeholder: "15",
                min: 0,
                class: "form-input" %>
          </div>

          <div class="form-group">
            <%= form.label :cook_time, "Cook Time (minutes)" %>
            <%= form.number_field :cook_time, 
                placeholder: "30",
                min: 0,
                class: "form-input" %>
          </div>
        </div>
        
        <div class="time-display" data-recipe-form-target="timeDisplay">
          <p class="helper-text">Total time will be calculated automatically</p>
        </div>
      </div>
    </div>

    <!-- Ingredients Card -->
    <div class="form-card" data-recipe-form-target="card" data-card="ingredients">
      <div class="card-header" data-action="click->recipe-form#toggleCard">
        <div class="card-title">
          <span class="card-icon">🥘</span>
          <h3>Ingredients</h3>
          <span class="card-status" data-recipe-form-target="ingredientsStatus">Required</span>
        </div>
        <button type="button" class="expand-btn" data-recipe-form-target="ingredientsToggle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
      
      <div class="card-body collapsed" data-recipe-form-target="ingredientsBody">
        <!-- Quick Add: Free-text area -->
        <div class="quick-add-section" data-recipe-form-target="quickAddSection">
          <div class="form-group">
            <label class="quick-add-label">
              ⚡ Quick Add
              <span class="helper-text-inline">Paste or type ingredients, one per line</span>
            </label>
            <textarea 
              rows="5"
              placeholder="2 cups all-purpose flour&#10;1 cup butter, softened&#10;3 large eggs&#10;1 teaspoon vanilla extract"
              class="form-input ingredients-textarea"
              data-recipe-form-target="quickAddTextarea"
            ></textarea>
          </div>
          <button type="button" 
                  class="btn btn-primary btn-parse"
                  data-action="click->recipe-form#parseIngredients">
            🔍 Parse Ingredients
          </button>
        </div>

        <div class="ingredients-divider">
          <span>or add manually</span>
        </div>

        <!-- Structured Ingredient Rows -->
        <div class="structured-ingredients" data-recipe-form-target="ingredientRows">
          <div class="ingredient-row-header">
            <span class="col-qty">Qty</span>
            <span class="col-unit">Unit</span>
            <span class="col-name">Ingredient</span>
            <span class="col-notes">Notes</span>
            <span class="col-action"></span>
          </div>

          <% if recipe.recipe_ingredients.any? %>
            <% recipe.recipe_ingredients.includes(:ingredient).each_with_index do |ri, i| %>
              <div class="ingredient-row" data-recipe-form-target="ingredientRow">
                <input type="number" step="any" min="0"
                       name="recipe[ingredients_rows][][quantity]"
                       value="<%= ri.quantity %>"
                       placeholder="2"
                       class="form-input col-qty">
                <select name="recipe[ingredients_rows][][unit]" class="form-select col-unit">
                  <option value="">—</option>
                  <optgroup label="Volume">
                    <option value="cups" <%= 'selected' if ri.unit == 'cups' %>>cups</option>
                    <option value="tablespoons" <%= 'selected' if ri.unit == 'tablespoons' %>>tbsp</option>
                    <option value="teaspoons" <%= 'selected' if ri.unit == 'teaspoons' %>>tsp</option>
                    <option value="milliliters" <%= 'selected' if ri.unit == 'milliliters' %>>ml</option>
                    <option value="liters" <%= 'selected' if ri.unit == 'liters' %>>liters</option>
                  </optgroup>
                  <optgroup label="Weight">
                    <option value="ounces" <%= 'selected' if ri.unit == 'ounces' %>>oz</option>
                    <option value="pounds" <%= 'selected' if ri.unit == 'pounds' %>>lbs</option>
                    <option value="grams" <%= 'selected' if ri.unit == 'grams' %>>grams</option>
                    <option value="kilograms" <%= 'selected' if ri.unit == 'kilograms' %>>kg</option>
                  </optgroup>
                  <optgroup label="Count">
                    <option value="whole" <%= 'selected' if ri.unit == 'whole' %>>whole</option>
                    <option value="pieces" <%= 'selected' if ri.unit == 'pieces' %>>pieces</option>
                    <option value="large" <%= 'selected' if ri.unit == 'large' %>>large</option>
                    <option value="medium" <%= 'selected' if ri.unit == 'medium' %>>medium</option>
                    <option value="small" <%= 'selected' if ri.unit == 'small' %>>small</option>
                    <option value="slices" <%= 'selected' if ri.unit == 'slices' %>>slices</option>
                    <option value="cloves" <%= 'selected' if ri.unit == 'cloves' %>>cloves</option>
                  </optgroup>
                  <optgroup label="Other">
                    <option value="pinch" <%= 'selected' if ri.unit == 'pinch' %>>pinch</option>
                    <option value="dash" <%= 'selected' if ri.unit == 'dash' %>>dash</option>
                    <option value="to_taste" <%= 'selected' if ri.unit == 'to_taste' %>>to taste</option>
                    <option value="cans" <%= 'selected' if ri.unit == 'cans' %>>cans</option>
                    <option value="bunches" <%= 'selected' if ri.unit == 'bunches' %>>bunches</option>
                    <option value="handfuls" <%= 'selected' if ri.unit == 'handfuls' %>>handfuls</option>
                    <option value="packages" <%= 'selected' if ri.unit == 'packages' %>>packages</option>
                    <option value="sticks" <%= 'selected' if ri.unit == 'sticks' %>>sticks</option>
                    <option value="spoons" <%= 'selected' if ri.unit == 'spoons' %>>spoons</option>
                  </optgroup>
                </select>
                <input type="text"
                       name="recipe[ingredients_rows][][name]"
                       value="<%= ri.ingredient.name %>"
                       placeholder="e.g., flour"
                       class="form-input col-name">
                <input type="text"
                       name="recipe[ingredients_rows][][notes]"
                       value="<%= ri.notes %>"
                       placeholder="optional"
                       class="form-input col-notes">
                <button type="button" class="btn-remove-row" data-action="click->recipe-form#removeIngredientRow" title="Remove">✕</button>
              </div>
            <% end %>
          <% end %>
        </div>

        <button type="button" 
                class="btn btn-ghost btn-add-row"
                data-action="click->recipe-form#addIngredientRow">
          + Add Ingredient
        </button>

        <div class="ingredient-count" data-recipe-form-target="ingredientCount">
          <p class="helper-text"><%= recipe.recipe_ingredients.size %> ingredients</p>
        </div>
      </div>
    </div>

    <!-- Instructions Card -->
    <div class="form-card" data-recipe-form-target="card" data-card="instructions">
      <div class="card-header" data-action="click->recipe-form#toggleCard">
        <div class="card-title">
          <span class="card-icon">👨‍🍳</span>
          <h3>Instructions</h3>
          <span class="card-status" data-recipe-form-target="instructionsStatus">Required</span>
        </div>
        <button type="button" class="expand-btn" data-recipe-form-target="instructionsToggle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
      
      <div class="card-body collapsed" data-recipe-form-target="instructionsBody">
        <div class="form-group">
          <%= form.label :instructions, "Cooking Steps" %>
          <p class="helper-text">
            <strong>Important:</strong> Separate each step with a blank line. Numbering is optional - we'll add numbers automatically!
          </p>
          <%= form.text_area :instructions,
              rows: 12,
              placeholder: "Preheat oven to 375°F (190°C).\n\nIn a large bowl, cream together butter and sugar until light and fluffy.\n\nBeat in eggs one at a time, then add vanilla extract.\n\nIn a separate bowl, whisk together flour, baking soda, and salt.\n\nGradually blend the dry ingredients into the creamed mixture.\n\nFold in chocolate chips.\n\nDrop rounded tablespoons of dough onto ungreased cookie sheets.\n\nBake for 10-12 minutes or until golden brown.\n\nCool on baking sheet for 2 minutes before removing to a wire rack.",
              class: "form-input instructions-textarea",
              data: { 
                recipe_form_target: "instructionsTextarea",
                action: "input->recipe-form#updateInstructionCount input->recipe-form#updateInstructionPreview" 
              } %>
        </div>
        
        <div class="instruction-count" data-recipe-form-target="instructionCount">
          <p class="helper-text">0 steps</p>
        </div>
        
        <div class="instruction-preview" data-recipe-form-target="instructionPreview" style="display: none;">
          <h4>Preview:</h4>
          <div class="preview-steps" data-recipe-form-target="instructionPreviewContent"></div>
        </div>
      </div>
    </div>

    <!-- Photo Card -->
    <div class="form-card" data-recipe-form-target="card" data-card="photo">
      <div class="card-header" data-action="click->recipe-form#toggleCard">
        <div class="card-title">
          <span class="card-icon">📸</span>
          <h3>Photo</h3>
          <span class="card-status">Optional</span>
        </div>
        <button type="button" class="expand-btn" data-recipe-form-target="photoToggle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
      
      <div class="card-body collapsed" data-recipe-form-target="photoBody">
        <div class="form-group">
          <%= form.label :image, "Upload a photo of your dish" %>
          <% if recipe.image.attached? %>
            <div style="margin-bottom: 16px;">
              <%= image_tag recipe.image, style: "max-width: 300px; border-radius: 8px;" %>
              <p class="helper-text">Upload a new image to replace this one</p>
            </div>
          <% end %>
          <div class="file-upload-wrapper">
            <%= form.file_field :image, 
                accept: "image/*",
                class: "file-input",
                data: { action: "change->recipe-form#previewImage" } %>
            <div class="file-upload-display" data-recipe-form-target="imagePreview">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
              <p>Click to upload or drag and drop</p>
              <p class="text-muted">PNG, JPG, GIF up to 10MB</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Source URL (Optional) -->
    <div class="form-card" data-recipe-form-target="card" data-card="source">
      <div class="card-header" data-action="click->recipe-form#toggleCard">
        <div class="card-title">
          <span class="card-icon">🔗</span>
          <h3>Source</h3>
          <span class="card-status">Optional</span>
        </div>
        <button type="button" class="expand-btn" data-recipe-form-target="sourceToggle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
      </div>
      
      <div class="card-body collapsed" data-recipe-form-target="sourceBody">
        <div class="form-group">
          <%= form.label :source_url, "Original Recipe URL" %>
          <%= form.text_field :source_url,
              placeholder: "https://example.com/recipe",
              class: "form-input" %>
          <p class="helper-text">If this recipe is adapted from another source, add the URL here</p>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="form-actions">
      <%= form.submit button_text, class: "btn btn-primary btn-large" %>
      <%= link_to "Cancel", recipe.new_record? ? recipes_path : recipe_path(recipe), class: "btn btn-secondary" %>
      <% if recipe.new_record? %>
        <button type="button" class="btn btn-ghost" data-action="click->recipe-form#saveDraft">
          Save Draft
        </button>
      <% end %>
    </div>

    <!-- Auto-save indicator (only for new recipes) -->
    <% if recipe.new_record? %>
      <div class="auto-save-indicator" data-recipe-form-target="saveIndicator">
        <span class="save-status">Draft saved</span>
      </div>
    <% end %>
  <% end %>
</div>

