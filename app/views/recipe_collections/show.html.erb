<div class="rc-show-container">
  <!-- Header -->
  <div class="rc-show-header">
    <div class="rc-show-header-content">
      <div>
        <h1 class="rc-show-title"><%= @collection.name %></h1>
        <% if @collection.description.present? %>
          <p class="rc-show-description"><%= @collection.description %></p>
        <% end %>
        <div class="rc-show-meta">
          <span>🍽️ <%= @collection.recipe_count %> <%= 'recipe'.pluralize(@collection.recipe_count) %></span>
          <span class="separator">•</span>
          <span>📅 Created <%= time_ago_in_words(@collection.created_at) %> ago</span>
        </div>
      </div>
      <div class="rc-show-actions">
        <%= link_to "✏️ Edit", edit_recipe_collection_path(@collection), class: "btn btn-secondary" %>
        <%= link_to "🗑️ Delete", @collection,
            data: { turbo_method: :delete, turbo_confirm: "Delete this collection and remove all recipes from it?" },
            class: "btn btn-danger" %>
      </div>
    </div>
  </div>

  <!-- Recipes Grid -->
  <% if @recipes.any? %>
    <div class="grid grid-3">
      <% @recipes.each do |recipe| %>
        <div class="recipe-card">
          <% if recipe.image.attached? %>
            <%= image_tag recipe.image, class: "recipe-card-image" %>
          <% else %>
            <div class="recipe-card-image"></div>
          <% end %>
          <div class="recipe-card-body">
            <h3 class="recipe-card-title"><%= link_to recipe.title, recipe %></h3>
            <p class="recipe-card-description"><%= truncate(recipe.description, length: 100) %></p>
            <div class="flex gap-2 mb-2">
              <% if recipe.prep_time %>
                <span>⏱️ <%= recipe.prep_time %>min</span>
              <% end %>
              <% if recipe.servings %>
                <span>🍽️ <%= recipe.servings %></span>
              <% end %>
              <% if recipe.difficulty %>
                <span>📊 <%= recipe.difficulty.capitalize %></span>
              <% end %>
            </div>
            <div class="flex gap-2">
              <%= link_to "View", recipe, class: "btn" %>
              <%= link_to "✕ Remove", remove_recipe_recipe_collection_path(@collection, recipe_id: recipe.friendly_id),
                  data: { turbo_method: :delete, turbo_confirm: "Remove this recipe from the collection?" },
                  class: "btn btn-danger" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="mt-4 text-center">
      <%= paginate @recipes %>
    </div>
  <% else %>
    <div class="card text-center">
      <div class="empty-state">
        <span class="empty-icon">📚</span>
        <h3>No recipes in this collection yet</h3>
        <p>Add recipes from your recipe pages using the "Add to Collection" button!</p>
        <%= link_to "Browse My Recipes", recipes_path, class: "btn btn-success mt-2" %>
      </div>
    </div>
  <% end %>

  <!-- Back Link -->
  <div class="back-link">
    <%= link_to "← Back to Collections", recipe_collections_path, class: "link-secondary" %>
  </div>
</div>
